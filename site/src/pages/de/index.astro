---
import Base from "../../layouts/Base.astro";
import { getUi } from "../../i18n/ui";
const base = import.meta.env.BASE_URL;
const ui = getUi("de");
---

<Base
  title={ui.homeTitle}
  description={ui.homeDescription}
  schemaType="WebSite"
  locale="de"
  routeKey="home"
>
  <section class="flex flex-col gap-6">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{ui.homeHeading}</h1>
    <p class="max-w-2xl text-lg">{ui.homeLead}</p>
    <div class="flex flex-wrap gap-4">
      <a
        href={`${base}de/about`}
        class="rounded-md bg-[var(--color-accent)] px-5 py-2.5 font-medium text-white no-underline hover:bg-[var(--color-accent-hover)]"
      >
        {ui.aboutKnowledgeBase}
      </a>
      <a
        href={`${base}de/glossary`}
        class="rounded-md border border-black/15 px-5 py-2.5 font-medium no-underline hover:bg-black/5 dark:border-white/15 dark:hover:bg-white/5"
      >
        {ui.glossaryIndex}
      </a>
    </div>
  </section>

  <section class="mt-20 flex flex-col gap-4">
    <h2 class="text-2xl font-semibold">{ui.firstOrientationLayer}</h2>
    <div class="grid gap-8 sm:grid-cols-2">
      <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.collectTerms}</h3>
        <p>{ui.collectTermsCopy}</p>
      </article>
      <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.clarifyDifferences}</h3>
        <p>{ui.clarifyDifferencesCopy}</p>
      </article>
      <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.understandingBeforeImplementation}</h3>
        <p>{ui.understandingBeforeImplementationCopy}</p>
      </article>
      <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.knowledgeBaseInProgress}</h3>
        <p>{ui.knowledgeBaseInProgressCopy}</p>
      </article>
    </div>
  </section>

  <section class="mt-20 flex flex-col gap-4">
    <h2 class="text-2xl font-semibold">{ui.firstOrientationLayer}</h2>
    <p class="max-w-3xl">{ui.firstOrientationLayerCopy}</p>
    <p>
      Die technische Referenz des Projekts bleibt unter <a href={`${base}docs`}>{ui.docs}</a> verfügbar,
      und der unterstützende Begriffsindex bleibt unter <a href={`${base}de/glossary`}>{ui.glossaryIndex}</a> erreichbar.
    </p>
  </section>
</Base>
