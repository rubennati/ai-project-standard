---
import Base from "../../layouts/Base.astro";
import { getUi } from "../../i18n/ui";
const ui = getUi("de");
---

<Base
  title={`${ui.aboutTitle} — AI Project Standard`}
  description={ui.aboutDescription}
  schemaType="AboutPage"
  locale="de"
  routeKey="about"
>
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{ui.aboutTitle}</h1>

  <section class="mt-8 flex flex-col gap-4">
    <p class="max-w-3xl">{ui.aboutIntro}</p>
    <p class="max-w-3xl">{ui.aboutLayerCopy}</p>
  </section>

  <section class="mt-12 flex flex-col gap-3">
    <h2 class="text-2xl font-semibold">{ui.maintainer}</h2>
    <p>
      Erstellt und gepflegt von <a href="https://github.com/rubennati">Ruben Nati</a>. Beiträge
      sind willkommen. Siehe dazu den
      <a href="https://github.com/rubennati/ai-project-standard/blob/main/CONTRIBUTING.md">Contribution Guide</a>.
    </p>
  </section>

  <section class="mt-10 flex flex-col gap-3">
    <h2 class="text-2xl font-semibold">{ui.license}</h2>
    <p>
      Veröffentlicht unter der MIT-Lizenz. Siehe die
      <a href="https://github.com/rubennati/ai-project-standard/blob/main/LICENSE">LICENSE</a>-Datei.
    </p>
  </section>

  <section class="mt-10 flex flex-col gap-3">
    <h2 class="text-2xl font-semibold">{ui.acknowledgements}</h2>
    <p>{ui.acknowledgementsCopy}</p>
  </section>
</Base>
