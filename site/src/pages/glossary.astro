---
import GlossaryIndexContent from "../components/glossary/GlossaryIndexContent.astro";
import { terms } from "../data/terms";
import { getUi } from "../i18n/ui";
import Base from "../layouts/Base.astro";
const ui = getUi("en");
---

<Base
  title={ui.glossaryTitle}
  description={ui.glossaryDescription}
  schemaType="CollectionPage"
  locale="en"
  routeKey="glossaryIndex"
>
  <GlossaryIndexContent lang="en" terms={terms} />
</Base>
