---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
---

<Base
  title="Profiles — AI Project Standard"
  description="Three adoption profiles: OSS-only, AI-only, and Combined."
  schemaType="CollectionPage"
>
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Profiles</h1>
  <p class="mt-4 max-w-2xl opacity-80">
    Three profiles share one repository and one version stream. Pick the profile that matches your context.
    Detailed file lists live in <a href={`${base}docs/profiles`}>the profiles doc</a>.
  </p>

  <section class="mt-12 grid gap-8 sm:grid-cols-3">
    <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
      <h2 class="text-xl font-semibold">OSS-only</h2>
      <p class="opacity-80">
        README, LICENSE, CONTRIBUTING, SECURITY, code of conduct, issue and PR templates, CI workflow,
        Git workflow docs.
      </p>
      <p class="opacity-80">No AI files.</p>
    </article>

    <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
      <h2 class="text-xl font-semibold">AI-only</h2>
      <p class="opacity-80">
        <code>AGENTS.md</code>, tool-specific pointer files (Claude Code, Copilot, Cursor), the
        <code>.ai/</code> operational workspace, and AI-collaboration docs.
      </p>
      <p class="opacity-80">Drops into an existing repository.</p>
    </article>

    <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
      <h2 class="text-xl font-semibold">Combined</h2>
      <p class="opacity-80">
        The union of both baselines. The working reference in this repository.
      </p>
      <p class="opacity-80">Available as a GitHub template from v0.2.0.</p>
    </article>
  </section>

  <section class="mt-16 flex flex-col gap-3">
    <h2 class="text-2xl font-semibold">How to adopt</h2>
    <p class="opacity-80">
      The adoption guide walks through each profile and a recommended workflow for keeping in sync with new
      releases of the standard.
    </p>
    <a
      href={`${base}docs/adoption`}
      class="w-fit rounded-md bg-[var(--color-accent)] px-5 py-2.5 font-medium text-white no-underline hover:opacity-90"
    >
      Adoption guide
    </a>
  </section>

  <p class="mt-12 text-sm opacity-60">
    The rich profiles page (interactive comparison, in-page file lists) lands in a later release. This v0.2.0
    page is intentionally minimal.
  </p>
</Base>
