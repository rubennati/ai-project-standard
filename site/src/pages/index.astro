---
import Base from "../layouts/Base.astro";
import { getUi } from "../i18n/ui";
const base = import.meta.env.BASE_URL;
const ui = getUi("en");
---

<Base
  title={ui.homeTitle}
  description={ui.homeDescription}
  schemaType="WebSite"
  locale="en"
  routeKey="home"
>
  <section class="flex flex-col gap-6 rounded-2xl border border-black/10 bg-black/[0.02] px-6 py-8 dark:border-white/10 dark:bg-white/[0.03] sm:px-8 sm:py-10">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">{ui.homeHeading}</h1>
    <p class="max-w-3xl text-lg leading-8">{ui.homeLead}</p>
    <div class="flex flex-wrap gap-4">
      <a
        href={`${base}about`}
        class="rounded-md bg-[var(--color-accent)] px-5 py-2.5 font-medium text-white no-underline hover:bg-[var(--color-accent-hover)]"
      >
        {ui.aboutKnowledgeBase}
      </a>
      <a
        href={`${base}glossary`}
        class="rounded-md border border-black/15 px-5 py-2.5 font-medium no-underline hover:bg-black/5 dark:border-white/15 dark:hover:bg-white/5"
      >
        {ui.glossarySecondaryLink}
      </a>
    </div>
  </section>

  <section class="mt-20 flex flex-col gap-4">
    <h2 class="text-2xl font-semibold">{ui.whatThisSiteIsFor}</h2>
    <div class="grid gap-6 sm:grid-cols-2">
      <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.collectTerms}</h3>
        <p>{ui.collectTermsCopy}</p>
      </article>
      <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.clarifyDifferences}</h3>
        <p>{ui.clarifyDifferencesCopy}</p>
      </article>
      <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.understandingBeforeImplementation}</h3>
        <p>{ui.understandingBeforeImplementationCopy}</p>
      </article>
      <article class="flex flex-col gap-2 rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.knowledgeBaseInProgress}</h3>
        <p>{ui.knowledgeBaseInProgressCopy}</p>
      </article>
    </div>
  </section>

  <section class="mt-20 flex flex-col gap-4">
    <h2 class="text-2xl font-semibold">{ui.whatIsAvailableNow}</h2>
    <p class="max-w-3xl leading-7">{ui.whatIsAvailableNowCopy}</p>
    <div class="grid gap-6 sm:grid-cols-3">
      <article class="rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.glossaryNow}</h3>
        <p class="mt-2 leading-7">{ui.glossaryNowCopy}</p>
      </article>
      <article class="rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.termPagesNow}</h3>
        <p class="mt-2 leading-7">{ui.termPagesNowCopy}</p>
      </article>
      <article class="rounded-lg border border-black/10 p-6 dark:border-white/10">
        <h3 class="text-lg font-semibold">{ui.docsNow}</h3>
        <p class="mt-2 leading-7">{ui.docsNowCopy}</p>
      </article>
    </div>
  </section>
</Base>
