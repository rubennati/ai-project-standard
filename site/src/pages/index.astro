---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL;
---

<Base title="AI Project Standard" description="A reusable repository standard for long-term human and AI collaboration. Open Source baseline plus Human-AI Collaboration baseline.">
  <section class="flex flex-col gap-6">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      A repository standard for long-term human and AI collaboration.
    </h1>
    <p class="max-w-2xl text-lg opacity-80">
      Both a reusable template and a reference implementation. Adopt the Open Source baseline,
      the Human-AI Collaboration baseline, or both — in one repository, one version stream.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href={`${base}use-cases`}
        class="rounded-md bg-[var(--color-accent)] px-5 py-2.5 font-medium text-white no-underline hover:opacity-90"
      >
        See the use cases
      </a>
      <a
        href={`${base}profiles`}
        class="rounded-md border border-black/15 px-5 py-2.5 font-medium no-underline hover:bg-black/5 dark:border-white/15 dark:hover:bg-white/5"
      >
        Compare profiles
      </a>
    </div>
  </section>

  <section class="mt-20 grid gap-8 sm:grid-cols-3">
    <article class="flex flex-col gap-2">
      <h2 class="text-xl font-semibold">OSS-only</h2>
      <p class="opacity-80">
        Governance, contribution rules, security policy, and CI for a credible open-source project.
        No AI files.
      </p>
    </article>
    <article class="flex flex-col gap-2">
      <h2 class="text-xl font-semibold">AI-only</h2>
      <p class="opacity-80">
        Source-of-truth instructions, an operational <code>.ai/</code> workspace, and multi-tool pointer files.
        Drops into an existing repository.
      </p>
    </article>
    <article class="flex flex-col gap-2">
      <h2 class="text-xl font-semibold">Combined</h2>
      <p class="opacity-80">
        Both baselines in one repository — the full reference implementation, ready as a GitHub template.
      </p>
    </article>
  </section>

  <section class="mt-20 flex flex-col gap-3">
    <h2 class="text-2xl font-semibold">Why it exists</h2>
    <p class="max-w-3xl opacity-80">
      Many repositories carry prompts but lack durable structure, review rules, and continuity practices.
      This standard fills that gap with short, opinionated files that work across Claude, Codex, GitHub Copilot,
      and Cursor — without forcing a particular tool on adopters.
    </p>
  </section>
</Base>
