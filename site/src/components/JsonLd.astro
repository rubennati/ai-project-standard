---
/**
 * JSON-LD structured data for search engines.
 *
 * Renders page-aware schemas. The homepage gets Organization + WebSite, while
 * other pages get a page-level schema by default. Page-specific schemas
 * (BreadcrumbList, Article, etc.) can be appended via the `extra` prop.
 */
interface Props {
  title: string;
  description: string;
  pageType?: "WebSite" | "WebPage" | "AboutPage" | "CollectionPage" | "Article";
  extra?: Record<string, unknown>[];
}

const { title, description, pageType = "WebPage", extra = [] } = Astro.props;

const site = Astro.site?.toString() ?? "https://ai-standard.rubennati.at/";
const repoUrl = "https://github.com/rubennati/ai-project-standard";
const pageUrl = Astro.url.toString();
const isHomePage = Astro.url.pathname === "/";

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "AI Project Standard",
  url: site,
  logo: `${site}icon.svg`,
  sameAs: [repoUrl],
};

const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "AI Project Standard",
  url: site,
  description:
    "A starting baseline for open-source projects that use AI. Four pillars: human-AI collaboration, open-source operations, engineering operations, knowledge and documentation.",
};

const page = {
  "@context": "https://schema.org",
  "@type": pageType,
  name: title,
  description,
  url: pageUrl,
  isPartOf: {
    "@type": "WebSite",
    name: "AI Project Standard",
    url: site,
  },
};

const baseSchemas = isHomePage ? [organization, website] : [page];
const schemas = [...baseSchemas, ...extra];
---

{
  schemas.map((schema) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
  ))
}
