---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import JsonLd from "../components/JsonLd.astro";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
  schemaType?: "WebSite" | "WebPage" | "AboutPage" | "CollectionPage" | "Article";
  extraSchemas?: Record<string, unknown>[];
}

const {
  title,
  description = "A repository standard for long-term human and AI collaboration.",
  ogType = "website",
  schemaType = "WebPage",
  extraSchemas = [],
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a3a8c" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#243b66" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={`${base}icon.svg`} type="image/svg+xml" />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <SEO title={title} description={description} ogType={ogType} />
    <JsonLd title={title} description={description} pageType={schemaType} extra={extraSchemas} />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <header class="border-b border-black/10 dark:border-white/10">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href={base} class="font-semibold no-underline">AI Project Standard</a>
        <ul class="flex gap-6 text-sm">
          <li><a href={`${base}use-cases`}>Use cases</a></li>
          <li><a href={`${base}profiles`}>Profiles</a></li>
          <li><a href={`${base}docs`}>Docs</a></li>
          <li><a href={`${base}blog`}>Blog</a></li>
          <li><a href={`${base}about`}>About</a></li>
        </ul>
      </nav>
    </header>

    <main id="main-content" class="mx-auto w-full max-w-5xl flex-1 px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-black/10 dark:border-white/10">
      <div class="mx-auto flex max-w-5xl flex-col gap-2 px-6 py-6 text-sm sm:flex-row sm:justify-between">
        <span class="text-zinc-700 dark:text-zinc-300">AI Project Standard — MIT licensed.</span>
        <a href="https://github.com/rubennati/ai-project-standard" class="font-medium">Source on GitHub</a>
      </div>
    </footer>
  </body>
</html>
