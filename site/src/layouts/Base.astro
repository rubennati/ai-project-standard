---
import "../styles/global.css";
import SEO from "../components/SEO.astro";
import JsonLd from "../components/JsonLd.astro";
import GlossaryLanguageSwitch from "../components/glossary/GlossaryLanguageSwitch.astro";
import { getAlternateLocale, getLocalizedPath, type LocalizedRouteKey } from "../i18n/routes";
import { getUi, type SiteLocale } from "../i18n/ui";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
  schemaType?: "WebSite" | "WebPage" | "AboutPage" | "CollectionPage" | "Article";
  extraSchemas?: Record<string, unknown>[];
  locale?: SiteLocale;
  routeKey?: LocalizedRouteKey;
  termSlug?: string;
}

const {
  title,
  description = "A repository standard for long-term human and AI collaboration.",
  ogType = "website",
  schemaType = "WebPage",
  extraSchemas = [],
  locale = "en",
  routeKey,
  termSlug,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const ui = getUi(locale);
const alternateLocale = getAlternateLocale(locale);
const lang = locale;
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const toHref = (path: string) => (path === "/" ? base : `${base}${path.replace(/^\//, "")}`);
const localizedHome = toHref(getLocalizedPath(locale, "home"));
const localizedAbout = toHref(getLocalizedPath(locale, "about"));
const localizedGlossary = toHref(getLocalizedPath(locale, "glossaryIndex"));
const localizedLegal = toHref(getLocalizedPath(locale, "legalNotice"));
const localizedPrivacy = toHref(getLocalizedPath(locale, "privacyPolicy"));
const docsHref = `${base}docs`;
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return currentPath === normalized || (normalized !== "/" && currentPath.startsWith(`${normalized}/`));
};
const hasAlternate = Boolean(routeKey);
const alternatePath = routeKey
  ? getLocalizedPath(alternateLocale, routeKey, routeKey === "glossaryTerm" ? { slug: termSlug } : undefined)
  : undefined;
const alternates = routeKey
  ? [
      { hreflang: "en", href: toHref(getLocalizedPath("en", routeKey, routeKey === "glossaryTerm" ? { slug: termSlug } : undefined)) },
      { hreflang: "de", href: toHref(getLocalizedPath("de", routeKey, routeKey === "glossaryTerm" ? { slug: termSlug } : undefined)) },
    ]
  : [];
const xDefaultHref = routeKey ? toHref(getLocalizedPath("en", routeKey, routeKey === "glossaryTerm" ? { slug: termSlug } : undefined)) : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a3a8c" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#243b66" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href={`${base}icon.svg`} type="image/svg+xml" />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <SEO title={title} description={description} ogType={ogType} alternates={alternates} xDefaultHref={xDefaultHref} />
    <JsonLd title={title} description={description} pageType={schemaType} extra={extraSchemas} lang={lang} />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main-content" class="skip-link">{ui.skipToMain}</a>
    <header class="border-b border-black/10 bg-white/85 backdrop-blur-sm dark:border-white/10 dark:bg-zinc-950/80">
      <div class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-10">
          <a href={localizedHome} class="shrink-0 no-underline text-black dark:text-white">
            <span class="block text-base font-semibold tracking-tight">AI Project Standard</span>
            <span class="mt-1 block text-xs uppercase tracking-[0.18em] text-zinc-500 dark:text-zinc-400">
              {ui.brandTagline}
            </span>
          </a>
          <nav aria-label={ui.primaryNavigation} class="flex flex-wrap items-center gap-2 text-sm">
            <a
              href={localizedHome}
              aria-current={isActive(localizedHome) ? "page" : undefined}
              class:list={{
                "rounded-full border px-3 py-1.5 no-underline transition": true,
                "border-black/10 bg-black/[0.045] font-semibold text-black dark:border-white/10 dark:bg-white/[0.12] dark:text-white":
                  isActive(localizedHome),
                "border-transparent text-zinc-700 hover:border-black/10 hover:bg-black/[0.03] hover:text-black dark:text-zinc-300 dark:hover:border-white/10 dark:hover:bg-white/[0.08] dark:hover:text-white":
                  !isActive(localizedHome),
              }}
            >
              {ui.home}
            </a>
            <a
              href={docsHref}
              aria-current={isActive(docsHref) ? "page" : undefined}
              class:list={{
                "rounded-full border px-3 py-1.5 no-underline transition": true,
                "border-black/10 bg-black/[0.045] font-semibold text-black dark:border-white/10 dark:bg-white/[0.12] dark:text-white":
                  isActive(docsHref),
                "border-transparent text-zinc-700 hover:border-black/10 hover:bg-black/[0.03] hover:text-black dark:text-zinc-300 dark:hover:border-white/10 dark:hover:bg-white/[0.08] dark:hover:text-white":
                  !isActive(docsHref),
              }}
            >
              {ui.docs}
            </a>
            <a
              href={localizedAbout}
              aria-current={isActive(localizedAbout) ? "page" : undefined}
              class:list={{
                "rounded-full border px-3 py-1.5 no-underline transition": true,
                "border-black/10 bg-black/[0.045] font-semibold text-black dark:border-white/10 dark:bg-white/[0.12] dark:text-white":
                  isActive(localizedAbout),
                "border-transparent text-zinc-700 hover:border-black/10 hover:bg-black/[0.03] hover:text-black dark:text-zinc-300 dark:hover:border-white/10 dark:hover:bg-white/[0.08] dark:hover:text-white":
                  !isActive(localizedAbout),
              }}
            >
              {ui.about}
            </a>
          </nav>
        </div>
        <div class="flex items-center justify-end lg:pl-6">
          {
            hasAlternate && alternatePath && (
              <GlossaryLanguageSwitch
                currentLang={locale}
                enHref={toHref(getLocalizedPath("en", routeKey!, routeKey === "glossaryTerm" ? { slug: termSlug } : undefined))}
                deHref={toHref(getLocalizedPath("de", routeKey!, routeKey === "glossaryTerm" ? { slug: termSlug } : undefined))}
              />
            )
          }
        </div>
      </div>
    </header>

    <main id="main-content" class="mx-auto w-full max-w-5xl flex-1 px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-black/10 dark:border-white/10">
      <div class="mx-auto flex max-w-5xl flex-col gap-4 px-6 py-6 text-sm sm:flex-row sm:items-center sm:justify-between">
        <span class="text-zinc-700 dark:text-zinc-300">AI Project Standard — MIT licensed.</span>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-zinc-700 dark:text-zinc-300">
          <a href={localizedGlossary} class="font-medium">{ui.glossaryIndex}</a>
          <a href={localizedLegal} class="font-medium">{ui.legalNotice}</a>
          <a href={localizedPrivacy} class="font-medium">{ui.privacyPolicy}</a>
          <a href="https://github.com/rubennati/ai-project-standard" class="font-medium">{ui.sourceOnGitHub}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
